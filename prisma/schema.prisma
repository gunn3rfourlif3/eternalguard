generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // URL IS REMOVED FROM HERE IN PRISMA 7
}
model VaultItem {
  id        String   @id @default(cuid())
  title     String
  content   String   // Encrypted payload
  category  String   // e.g., 'Vault', 'Medical', 'Wealth', 'Guardians', 'Legacy', 'Claim'
  type      String?  // e.g., 'Document', 'Note', 'Credential'
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    String
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId, category]) // Index for high-speed pillar filtering
}

model User {
  id                     String   @id @default(uuid())
  fullName               String
  email                  String   @unique
  securityPin            String
  verificationPercentage Int      @default(0)
  isPremiumPaid          Boolean  @default(false)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  items                  VaultItem[]
}