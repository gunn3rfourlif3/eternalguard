generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // URL IS REMOVED FROM HERE IN PRISMA 7
}
model VaultItem {
  id        String   @id @default(uuid())
  title     String
  content   String   // This will store your encrypted data
  category  String   @default("General")
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id                     String   @id @default(uuid())
  fullName               String
  email                  String   @unique
  securityPin            String
  verificationPercentage Int      @default(0)
  isPremiumPaid          Boolean  @default(false)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  items                  VaultItem[]
}